## 5. MongoTemplate — Dynamic Queries

Use MongoTemplate when filters are dynamic (the user may or may not provide certain parameters)
or when method names would be too long. The Criteria API is type-safe and avoids raw string bugs.

```java
@Service
@RequiredArgsConstructor
public class OrderQueryService {

    private final MongoTemplate mongoTemplate;

    // Dynamic search — repo method names can't handle optional parameters cleanly
    public Page<Order> searchOrders(String userId, OrderStatus status,
                                    LocalDateTime from, LocalDateTime to, Pageable pageable) {
        Criteria criteria = new Criteria();
        if (StringUtils.hasText(userId))    criteria = criteria.and("user_id").is(userId);
        if (status != null)                  criteria = criteria.and("order_status").is(status);
        if (from != null && to != null)      criteria = criteria.and("created_at").gte(from).lte(to);

        Query query = new Query(criteria);
        long total = mongoTemplate.count(query, Order.class);  // count BEFORE adding limit
        query.with(pageable);
        return new PageImpl<>(mongoTemplate.find(query, Order.class), pageable, total);
    }

    // Partial update — avoids loading the full document into heap
    public void markShipped(String orderId, String trackingNumber) {
        Query q = new Query(Criteria.where("_id").is(orderId));
        Update u = new Update()
            .set("order_status", OrderStatus.SHIPPED)
            .set("tracking_number", trackingNumber)
            .set("updated_at", LocalDateTime.now());
        mongoTemplate.updateFirst(q, u, Order.class);
    }

    // Atomic increment (e.g. retry counter)
    public void incrementRetryCount(String orderId) {
        mongoTemplate.updateFirst(
            new Query(Criteria.where("_id").is(orderId)),
            new Update().inc("retry_count", 1),
            Order.class
        );
    }

    // Push to embedded array without loading the document
    public void addLineItem(String orderId, LineItem item) {
        mongoTemplate.updateFirst(
            new Query(Criteria.where("_id").is(orderId)),
            new Update().push("line_items", item),
            Order.class
        );
    }

    // Upsert — create if not exists, update if exists
    public void upsertPreference(String userId, String key, String value) {
        mongoTemplate.upsert(
            new Query(Criteria.where("user_id").is(userId)),
            new Update().set("preferences." + key, value).setOnInsert("user_id", userId),
            UserPreference.class
        );
    }
}
```

