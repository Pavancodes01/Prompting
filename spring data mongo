## 1. Entity Class

The main Java class that maps to a MongoDB collection. Every decision here — collection name,
field mapping, indexes — must come from what `find` and `list_indexes` MCP calls revealed.

```java
package com.example.domain;

import lombok.Builder;
import lombok.Data;
import org.springframework.data.annotation.CreatedDate;
import org.springframework.data.annotation.Id;
import org.springframework.data.annotation.LastModifiedDate;
import org.springframework.data.mongodb.core.index.CompoundIndex;
import org.springframework.data.mongodb.core.index.CompoundIndexes;
import org.springframework.data.mongodb.core.index.Indexed;
import org.springframework.data.mongodb.core.mapping.Document;
import org.springframework.data.mongodb.core.mapping.Field;
import java.time.LocalDateTime;
import java.util.List;

@Data
@Builder
@Document(collection = "orders")           // exact name from list_collections
@CompoundIndexes({                         // compound indexes from list_indexes at class level
    @CompoundIndex(name = "status_date_idx", def = "{'order_status':1, 'created_at':-1}"),
    @CompoundIndex(name = "user_status_idx", def = "{'user_id':1, 'order_status':1}")
})
public class Order {

    @Id
    private String id;                     // always String — Spring handles ObjectId conversion

    @Field("user_id")                      // DB uses snake_case — @Field bridges to camelCase
    @Indexed                               // single index from list_indexes
    private String userId;

    @Field("order_status")
    private OrderStatus status;            // enum — stored as String in MongoDB

    @Field("total_amount")
    private Double totalAmount;

    private String currency;               // field name matches Java — no @Field needed

    @Field("line_items")
    private List<LineItem> lineItems;      // embedded array

    @Field("shipping_address")
    private ShippingAddress shippingAddress; // embedded object

    @Field("created_at")
    @CreatedDate                           // auto-set on insert (needs @EnableMongoAuditing)
    private LocalDateTime createdAt;

    @Field("updated_at")
    @LastModifiedDate                      // auto-updated on every save
    private LocalDateTime updatedAt;

    @Field("expires_at")
    @Indexed(expireAfterSeconds = 604800)  // TTL index — auto-delete after 7 days
    private LocalDateTime expiresAt;
}
```

