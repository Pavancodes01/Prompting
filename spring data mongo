## 8. Pagination

```java
// Service — return Page<DTO> not Page<Entity>
public Page<OrderSummaryDto> getOrdersByStatus(String status, int page, int size) {
    Pageable pageable = PageRequest.of(page, size, Sort.by(Sort.Direction.DESC, "created_at"));
    return orderRepository.findByStatus(OrderStatus.valueOf(status), pageable)
                          .map(OrderSummaryDto::from);
}

// Controller
@GetMapping("/orders")
public ResponseEntity<Page<OrderSummaryDto>> getOrders(
    @RequestParam String status,
    @RequestParam(defaultValue = "0") int page,
    @RequestParam(defaultValue = "20") int size) {
    return ResponseEntity.ok(orderService.getOrdersByStatus(status, page, size));
}
