## Section E — Test Cases

**Purpose:** JUnit 5 tests that verify the generated code works. Both files must be complete
and runnable without any changes by the user.

Two files always:

1. `*RepositoryTest` — uses `@DataMongoTest` (real embedded MongoDB, no mocks)
1. `*ServiceTest` — uses `@ExtendWith(MockitoExtension.class)` (mocked repository, fast)

```markdown
## E. Test Cases

### OrderRepositoryTest.java
\`\`\`java
package com.example.repository;

import com.example.domain.Order;
import com.example.domain.OrderStatus;
import org.junit.jupiter.api.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.data.mongo.DataMongoTest;
import org.springframework.data.domain.*;

import java.time.LocalDateTime;
import java.util.List;

import static org.assertj.core.api.Assertions.assertThat;

@DataMongoTest
class OrderRepositoryTest {

    @Autowired OrderRepository orderRepository;

    Order order1, order2;

    @BeforeEach
    void setUp() {
        orderRepository.deleteAll();
        order1 = orderRepository.save(Order.builder()
            .userId("user-1").status(OrderStatus.COMPLETED)
            .totalAmount(1500.0).currency("USD")
            .createdAt(LocalDateTime.now().minusDays(1)).build());
        order2 = orderRepository.save(Order.builder()
            .userId("user-1").status(OrderStatus.PENDING)
            .totalAmount(500.0).currency("USD")
            .createdAt(LocalDateTime.now()).build());
    }

    @AfterEach
    void tearDown() { orderRepository.deleteAll(); }

    @Test
    @DisplayName("findByUserId - returns all orders for user with pagination")
    void findByUserId_returnsPaginatedOrders() {
        Page<Order> result = orderRepository.findByUserId("user-1", PageRequest.of(0, 10));
        assertThat(result.getTotalElements()).isEqualTo(2);
        assertThat(result.getContent()).extracting(Order::getUserId).containsOnly("user-1");
    }

    @Test
    @DisplayName("findByUserId - unknown user returns empty page")
    void findByUserId_unknownUserReturnsEmpty() {
        Page<Order> result = orderRepository.findByUserId("no-such-user", PageRequest.of(0, 10));
        assertThat(result.getTotalElements()).isZero();
    }

    @Test
    @DisplayName("findByUserIdAndStatus - filters by both user and status")
    void findByUserIdAndStatus_filtersCorrectly() {
        Page<Order> result = orderRepository.findByUserIdAndStatus(
            "user-1", OrderStatus.COMPLETED, PageRequest.of(0, 10));
        assertThat(result.getContent()).hasSize(1);
        assertThat(result.getContent().get(0).getStatus()).isEqualTo(OrderStatus.COMPLETED);
    }

    @Test
    @DisplayName("existsByUserIdAndStatus - true when match found")
    void existsByUserIdAndStatus_trueWhenFound() {
        assertThat(orderRepository.existsByUserIdAndStatus("user-1", OrderStatus.COMPLETED)).isTrue();
    }

    @Test
    @DisplayName("existsByUserIdAndStatus - false when no match")
    void existsByUserIdAndStatus_falseWhenNotFound() {
        assertThat(orderRepository.existsByUserIdAndStatus("user-1", OrderStatus.CANCELLED)).isFalse();
    }

    @Test
    @DisplayName("countByStatus - counts correctly")
    void countByStatus_returnsCorrectCount() {
        assertThat(orderRepository.countByStatus(OrderStatus.PENDING)).isEqualTo(1);
        assertThat(orderRepository.countByStatus(OrderStatus.COMPLETED)).isEqualTo(1);
    }
}
\`\`\`

### OrderServiceTest.java
\`\`\`java
package com.example.service;

import com.example.domain.Order;
import com.example.domain.OrderStatus;
import com.example.dto.OrderSummaryDto;
import com.example.exception.EntityNotFoundException;
import com.example.repository.OrderRepository;
import org.junit.jupiter.api.*;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.*;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.data.domain.*;

import java.util.*;

import static org.assertj.core.api.Assertions.*;
import static org.mockito.ArgumentMatchers.*;
import static org.mockito.Mockito.*;

@ExtendWith(MockitoExtension.class)
class OrderServiceTest {

    @Mock OrderRepository orderRepository;
    @InjectMocks OrderService orderService;

    @Test
    @DisplayName("getOrderHistory - returns paged DTOs for valid user")
    void getOrderHistory_returnsDtoPage() {
        Order order = Order.builder().id("o1").userId("u1")
            .status(OrderStatus.COMPLETED).totalAmount(1500.0).build();
        when(orderRepository.findByUserId(eq("u1"), any(Pageable.class)))
            .thenReturn(new PageImpl<>(List.of(order)));

        Page<OrderSummaryDto> result = orderService.getOrderHistory("u1", PageRequest.of(0, 10));

        assertThat(result.getContent()).hasSize(1);
        assertThat(result.getContent().get(0).id()).isEqualTo("o1");
        verify(orderRepository).findByUserId(eq("u1"), any(Pageable.class));
    }

    @Test
    @DisplayName("getOrderHistory - empty page when user has no orders")
    void getOrderHistory_emptyForUserWithNoOrders() {
        when(orderRepository.findByUserId(eq("u2"), any(Pageable.class))).thenReturn(Page.empty());
        Page<OrderSummaryDto> result = orderService.getOrderHistory("u2", PageRequest.of(0, 10));
        assertThat(result.getContent()).isEmpty();
    }

    @Test
    @DisplayName("getOrderById - throws EntityNotFoundException for unknown id")
    void getOrderById_throwsWhenNotFound() {
        when(orderRepository.findById("unknown")).thenReturn(Optional.empty());
        assertThatThrownBy(() -> orderService.getOrderById("unknown"))
            .isInstanceOf(EntityNotFoundException.class)
            .hasMessageContaining("unknown");
    }

    @Test
    @DisplayName("getOrderById - returns DTO when found")
    void getOrderById_returnsDtoWhenFound() {
        Order order = Order.builder().id("o1").status(OrderStatus.PENDING).totalAmount(750.0).build();
        when(orderRepository.findById("o1")).thenReturn(Optional.of(order));
        OrderSummaryDto result = orderService.getOrderById("o1");
        assertThat(result.id()).isEqualTo("o1");
        assertThat(result.status()).isEqualTo(OrderStatus.PENDING);
    }
}
\`\`\`
